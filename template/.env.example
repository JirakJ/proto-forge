# Copy to .env (git-ignored). Every var here is validated by src/config/env.ts (zod).
# No secrets in the repo — real values live only in your local .env.

# Base URL the app is served from (used for absolute links). Non-sensitive.
VITE_APP_BASE_URL=http://localhost:5173

# Persistence mode: "local" (Dexie/IndexedDB) or "api". Drives the infra adapter.
VITE_PERSISTENCE=local

# When VITE_PERSISTENCE=api, the base URL of the backend. Non-sensitive (public origin).
# VITE_API_BASE_URL=http://localhost:8787
