{
  "name": "proto-forge-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test:unit && pnpm run i18n:verify && pnpm run stub:scan && pnpm run adr:lint && pnpm run prompt:lint && pnpm run dup:scan && pnpm run consistency && pnpm run sec:scan && pnpm run snapshot:diff && pnpm run test:e2e",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "i18n:verify": "node scripts/i18n-verify.mjs",
    "i18n:extract": "i18next 'src/**/*.{ts,tsx}' && node scripts/pseudo-gen.mjs",
    "stub:scan": "node scripts/stub-scan.mjs",
    "adr:lint": "node scripts/adr-lint.mjs",
    "prompt:lint": "node scripts/prompt-log-lint.mjs",
    "dup:scan": "jscpd src packages/proto-ui/src --config .jscpd.json && node scripts/component-dup-scan.mjs",
    "consistency": "node scripts/consistency.mjs",
    "sec:scan": "node scripts/sec-scan.mjs && pnpm run sbom",
    "sbom": "node scripts/sbom.mjs",
    "snapshot": "node scripts/snapshot-diff.mjs --write",
    "seed:lock": "node scripts/snapshot-diff.mjs --write-seed",
    "snapshot:diff": "node scripts/snapshot-diff.mjs",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "dexie": "^4.0.11",
    "dompurify": "^3.2.4",
    "i18next": "^24.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^7.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.20.1",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.6",
    "eslint": "^9.20.1",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-i18next": "^6.1.1",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-no-unsanitized": "^4.1.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-security": "^3.0.1",
    "fake-indexeddb": "^6.0.0",
    "husky": "^9.1.7",
    "i18next-parser": "^9.3.0",
    "jsdom": "^26.0.0",
    "jscpd": "^4.0.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.1.1",
    "vitest": "^3.0.6"
  }
}
